# Root development services configuration.
#
# Copy this file to `.env` at repo root when you want to run shared local
# services such as PostgreSQL + pgvector or Ollama via Docker Compose.
#
# The desktop app's own runtime env lives at `apps/desktop/.env.example`.

# ---------------------------------------------------------------------------
# Docker Compose: PostgreSQL + pgvector
# ---------------------------------------------------------------------------
POSTGRES_DB=testing_ide
POSTGRES_USER=testing_ide
POSTGRES_PASSWORD=testing_ide_dev_password
POSTGRES_PORT=5432

# ---------------------------------------------------------------------------
# Docker Compose: Ollama
# ---------------------------------------------------------------------------
OLLAMA_PORT=11434
OLLAMA_KEEP_ALIVE=5m

# ---------------------------------------------------------------------------
# Desktop app runtime
# ---------------------------------------------------------------------------
# These are duplicated here for convenience when you want a single root-level
# `.env` file while working with both Docker Compose and the Tauri app.
#
# If you prefer per-app config, set the same values in `apps/desktop/.env`.

OLLAMA_BASE_URL=http://localhost:11434
LOG_LEVEL=info

# Minimum 32 bytes if set. Omit only for local throwaway development.
# JWT_SECRET=

# Native Rust/Tauri Sentry DSN
# SENTRY_DSN=https://<public_key>@<host>/<project_id>

# Browser-side public Sentry DSN
# VITE_SENTRY_DSN=https://<public_key>@<host>/<project_id>

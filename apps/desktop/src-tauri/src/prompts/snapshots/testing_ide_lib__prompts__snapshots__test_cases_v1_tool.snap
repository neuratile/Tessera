---
source: src/prompts/snapshots.rs
expression: "test_cases_v1::tool().parameters_schema"
---
additionalProperties: false
properties:
  cases:
    items:
      additionalProperties: false
      properties:
        expectedResult:
          minLength: 1
          type: string
        id:
          description: "Stable id, prefix `TC-`. MUST use ONLY uppercase letters, digits, hyphens, and underscores (e.g. 'TC-TEST-CARD-FOOTER' in all-caps, NOT 'TC-TEST-CARD-Footer')."
          pattern: "^TC-[A-Z0-9_-]+$"
          type: string
        preconditions:
          items:
            minLength: 1
            type: string
          type: array
        priority:
          enum:
            - p0
            - p1
            - p2
            - p3
          type: string
        steps:
          items:
            minLength: 1
            type: string
          type: array
        title:
          maxLength: 200
          minLength: 5
          type: string
        traceability:
          items:
            description: "Source reference such as `src/routes/auth.ts#login`."
            minLength: 1
            type: string
          type: array
      required:
        - id
        - title
        - priority
        - steps
        - expectedResult
      type: object
    type: array
  files:
    description: "Runnable workspace mirroring the cases: minimal source-under-test plus generated vitest specs, so the local sandbox can execute them. Optional — omit for descriptive-only cases."
    items:
      additionalProperties: false
      properties:
        contents:
          description: Full file contents.
          type: string
        isTest:
          description: true for a generated vitest spec; false for source-under-test.
          type: boolean
        path:
          description: "Workspace-relative path, e.g. `src/add.ts` or `add.test.ts`. No absolute paths, no `..`."
          minLength: 1
          type: string
      required:
        - path
        - contents
        - isTest
      type: object
    type: array
required:
  - cases
type: object

---
source: src/prompts/snapshots.rs
expression: "test_plan_v1::tool().parameters_schema"
---
additionalProperties: false
properties:
  entry_criteria:
    items:
      minLength: 1
      type: string
    minItems: 1
    type: array
  environments:
    items:
      additionalProperties: false
      properties:
        name:
          minLength: 1
          type: string
        purpose:
          minLength: 1
          type: string
      required:
        - name
        - purpose
      type: object
    type: array
  exit_criteria:
    items:
      minLength: 1
      type: string
    minItems: 1
    type: array
  objectives:
    items:
      minLength: 1
      type: string
    minItems: 1
    type: array
  risks:
    items:
      additionalProperties: false
      properties:
        description:
          minLength: 1
          type: string
        mitigation:
          minLength: 1
          type: string
        severity:
          enum:
            - critical
            - major
            - minor
            - trivial
          type: string
      required:
        - description
        - severity
        - mitigation
      type: object
    type: array
  scope_in:
    items:
      minLength: 1
      type: string
    minItems: 1
    type: array
  scope_out:
    items:
      minLength: 1
      type: string
    type: array
  summary:
    maxLength: 1500
    minLength: 40
    type: string
  test_types:
    items:
      additionalProperties: false
      properties:
        kind:
          enum:
            - unit
            - integration
            - end_to_end
            - performance
            - security
            - accessibility
          type: string
        rationale:
          minLength: 1
          type: string
      required:
        - kind
        - rationale
      type: object
    minItems: 1
    type: array
required:
  - summary
  - objectives
  - scope_in
  - scope_out
  - test_types
  - entry_criteria
  - exit_criteria
type: object

{
  "name": "@testing-ide/desktop",
  "version": "0.1.1",
  "private": true,
  "type": "module",
  "scripts": {
    "vite:dev": "node ../../node_modules/vite/bin/vite.js",
    "vite:build": "node ../../node_modules/vite/bin/vite.js build",
    "tauri": "node ./scripts/run-tauri-with-rust-path.mjs",
    "dev": "node ./scripts/run-tauri-with-rust-path.mjs dev",
    "build": "node ./scripts/run-tauri-with-rust-path.mjs build",
    "e2e:install": "node ./scripts/install-playwright-browser.mjs",
    "lint": "node ../../node_modules/eslint/bin/eslint.js .",
    "test:e2e": "node ./scripts/run-playwright-e2e.mjs",
    "test:frontend": "node ../../node_modules/vitest/vitest.mjs run --config vitest.config.ts",
    "test:integration": "node ../../node_modules/vitest/vitest.mjs run --config vitest.integration.config.ts",
    "test:rust": "cargo test --manifest-path src-tauri/Cargo.toml --locked -j 1 --lib",
    "test": "npm run test:frontend && npm run test:rust",
    "typecheck": "node ../../node_modules/typescript/bin/tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "@monaco-editor/react": "^4.6.0",
    "@radix-ui/react-slot": "^1.1.2",
    "@sentry/react": "^10.0.0",
    "@supabase/supabase-js": "^2.107.0",
    "@tauri-apps/api": "^2.2.0",
    "@tauri-apps/plugin-dialog": "^2",
    "@tauri-apps/plugin-fs": "^2",
    "@testing-ide/shared": "file:../../packages/shared",
    "@testing-ide/ui": "file:../../packages/ui",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "lucide-react": "^0.469.0",
    "monaco-editor": "^0.52.0",
    "react": "^19.0.0",
    "react-arborist": "^3.4.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^9.0.0",
    "react-resizable-panels": "^2.1.0",
    "remark-gfm": "^4.0.0",
    "tailwind-merge": "^2.6.0",
    "zod": "^3.24.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.17.0",
    "@playwright/test": "^1.55.0",
    "@tailwindcss/vite": "^4.0.0",
    "@tauri-apps/cli": "^2.2.0",
    "@types/node": "^22.10.0",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@vitejs/plugin-react": "^4.3.4",
    "eslint": "^9.17.0",
    "eslint-plugin-react-hooks": "^5.1.0",
    "eslint-plugin-react-refresh": "^0.4.16",
    "tailwindcss": "^4.0.0",
    "typescript": "~5.7.2",
    "typescript-eslint": "^8.18.0",
    "vite": "^6.0.0",
    "vitest": "^3.2.4"
  }
}

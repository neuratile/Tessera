# Testing IDE — backend environment variables.
#
# Copy to .env (gitignored) and edit. All values have safe defaults; only
# override when you need to point at a non-default Ollama instance, store
# the database somewhere other than the working directory, or change the
# tracing filter.
#
# Per rules.md §9: never commit a real .env. Per rules.md §13: env access
# is centralized in src/config.rs — do not read these vars from anywhere
# else in the codebase.

# Base URL for the Ollama OpenAI-compatible endpoint. Default targets a
# local Ollama install on the standard port.
OLLAMA_BASE_URL=http://localhost:11434

# Absolute or relative path to the SQLite database file. Created on first
# launch. Default is ./testing-ide.db relative to the working directory;
# the Tauri runtime overrides this with the OS user-data directory at
# bootstrap.
# DB_PATH=./testing-ide.db

# tracing-subscriber EnvFilter directive. Examples:
#   info
#   debug
#   testing_ide_lib=debug,sqlx=warn
LOG_LEVEL=info

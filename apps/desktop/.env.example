# Testing IDE — desktop app environment (Rust + Vite).
#
# Copy to `.env` alongside this file (gitignored). Values are optional
# unless marked required for your scenario. Per `rules.md` §13, the Rust
# binary reads these keys only through `src-tauri/src/config.rs`.
#
# Loading: `dotenvy` runs before boot (see `src-tauri/src/main.rs`), trying
# `./.env` then `apps/desktop/.env`.

# ---------------------------------------------------------------------------
# SQLite (optional override)
# ---------------------------------------------------------------------------
# When unset, the Tauri app uses `<app_local_data_dir>/testing-ide.db`.
# Set to point at a fixed file (dev or portable installs).
# DB_PATH=./testing-ide.db

# ---------------------------------------------------------------------------
# JWT (Phase 5 auth)
# ---------------------------------------------------------------------------
# Minimum 32 bytes when set. Omit in local dev to use the built-in dev-only
# fallback (do not ship builds that rely on that default).
# JWT_SECRET=

# JWT_ACCESS_TTL_SECS=900
# JWT_REFRESH_TTL_SECS=604800

# ---------------------------------------------------------------------------
# LLM — Ollama (OpenAI-compatible endpoint)
# ---------------------------------------------------------------------------
OLLAMA_BASE_URL=http://localhost:11434

# ---------------------------------------------------------------------------
# Observability
# ---------------------------------------------------------------------------
# tracing-subscriber env filter: `info`, `debug`, etc.
LOG_LEVEL=info

# Native / desktop Sentry DSN (omit or blank = reporting disabled until wired).
# SENTRY_DSN=https://<public_key>@<host>/<project_id>

# ---------------------------------------------------------------------------
# Vite frontend (must use VITE_ prefix to reach browser code).
# Never put secrets destined only for Rust in these — they bundle to the UI.
# ---------------------------------------------------------------------------
# VITE_SENTRY_DSN=https://<public_key>@<host>/<project_id>
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key
